# ── AVISO DE SEGURIDAD ─────────────────────────────────────────────────────────
# Nunca subas el archivo .env a un repositorio público.
# Asegurate de que .env esté listado en .gitignore.

# ── Credenciales por plataforma ───────────────────────────────────────────────
# Para cada plataforma configurada en config/platforms/<nombre>.json,
# agregá un par de variables usando el nombre en mayúsculas como prefijo:
#
#   {PLATAFORMA}_USERNAME=tu_usuario
#   {PLATAFORMA}_PASSWORD=tu_contraseña
#
# Ejemplo para una plataforma llamada "campus":
#   CAMPUS_USERNAME=juan.perez
#   CAMPUS_PASSWORD=miContraseña123

UPSO_USERNAME=tu_usuario
UPSO_PASSWORD=tu_contraseña

FADENA_USERNAME=tu_usuario
FADENA_PASSWORD=tu_contraseña

# ── Integraciones (tokens compartidos entre plataformas) ──────────────────────

# Todoist — generá tu token en:
# https://app.todoist.com/app/settings/integrations/developer
TODOIST_TOKEN=tu_token_de_todoist

# Notion — creá una integración en: https://www.notion.so/my-integrations
# El DATABASE_ID se obtiene de la URL de la base de datos (antes de "?v=").
NOTION_TOKEN=tu_token_de_notion
NOTION_DATABASE_ID=tu_database_id

# ── Habilitación de integraciones por plataforma ──────────────────────────────
# Controla si Todoist y Notion se ejecutan automáticamente al finalizar
# el pipeline para cada plataforma. Solo se activan con el valor "true".

UPSO_TODOIST_ENABLED=false
UPSO_NOTION_ENABLED=false

FADENA_TODOIST_ENABLED=false
FADENA_NOTION_ENABLED=false

# ── Nombres de propiedades Notion (opcional) ──────────────────────────────────
# Solo necesario si las columnas de tu base de datos difieren del esquema
# recomendado en el README. Los valores por defecto se muestran a continuación.
# NOTION_PROP_ARCHIVO=Archivo
# NOTION_PROP_CURSO=Curso
# NOTION_PROP_SEMANA=Semana
# NOTION_PROP_TEMA=Tema
# NOTION_PROP_PLATAFORMA=Plataforma
# NOTION_PROP_FECHA=Fecha
